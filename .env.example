# Si el frontend llama a http://localhost:8000, usa PORT=8000 (un solo proceso: auth + QA).
PORT=8000
DATABASE_URL=postgresql://user:password@localhost:5432/qa_microservice
OPENROUTER_API_KEY=sk-or-v1-xxxx
OPENROUTER_MODEL=openai/gpt-4o-mini
APP_BASE_URL=http://localhost:8000
REQUEST_TIMEOUT_MS=30000
WEBHOOK_MAX_RETRIES=2
ALLOWED_ORIGINS=*
INTERNAL_API_KEY=
# Firma JWT para /api/auth/* (obligatorio en producción con valor fuerte)
JWT_SECRET=
# Login único del panel (usuario y contraseña fijos)
AUTH_USERNAME=admin
AUTH_PASSWORD=cambia-esta-password
# Panel Next (redirige GET que no sean /api/* si alguien entra por el puerto del API)
FRONTEND_URL=http://localhost:3000
